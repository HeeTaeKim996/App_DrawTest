<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#BBBBBB"
    tools:context=".MainActivity">


    <!--        app:layout_constraintBottom_toBottomOf="parent"-->
<!--        app:layout_constraintEnd_toEndOf="parent"-->
<!--        app:layout_constraintHorizontal_bias="0.491"-->

<!--        app:layout_constraintStart_toStartOf="parent"-->
<!--        app:layout_constraintTop_toTopOf="parent"-->
<!--        app:layout_constraintVertical_bias="0.747"--><![CDATA[
        />







    ]]>

    <com.example.a33_plus_drawtest.PainterView
        android:id="@+id/paintCanvasView"
        android:layout_width="368dp"
        android:layout_height="467dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="57dp"
        android:layout_marginBottom="16dp"
        android:background="#FFFFFF"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.222"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/button_set_color_black"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginBottom="28dp"
        android:text="검정"
        app:layout_constraintBottom_toTopOf="@+id/paintCanvasView"
        app:layout_constraintStart_toStartOf="parent" />

    <Button
        android:id="@+id/button_set_color_blue"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="28dp"
        android:text="파랑"
        app:layout_constraintBottom_toTopOf="@+id/paintCanvasView"
        app:layout_constraintStart_toEndOf="@+id/button_set_color_black" />

    <Button
        android:id="@+id/button_eraser"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="1dp"
        android:layout_marginBottom="28dp"
        android:text="지우개"
        app:layout_constraintBottom_toTopOf="@+id/paintCanvasView"
        app:layout_constraintStart_toEndOf="@+id/button_erase_all" />

    <Button
        android:id="@+id/button_erase_all"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginBottom="28dp"
        android:text="다지워"
        app:layout_constraintBottom_toTopOf="@+id/paintCanvasView"
        app:layout_constraintStart_toEndOf="@+id/button_set_color_blue" />


</androidx.constraintlayout.widget.ConstraintLayout>
