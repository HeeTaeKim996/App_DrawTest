<?xml version="1.0" encoding="utf-8"?>
<com.example.a33_plus_drawtest.ZoomableConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background= "@color/white"
    android:clickable = "true"
    >


    <ScrollView
        android:layout_width="wrap_content"
        android:layout_height="0dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <com.example.a33_plus_drawtest.PageView
                android:id="@+id/page_view1"
                android:layout_width="377dp"
                android:layout_height="622dp"
                android:background="#888888">

                <com.example.a33_plus_drawtest.TextView
                    android:id="@+id/text_test"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"

                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.example.a33_plus_drawtest.PictureView
                    android:id="@+id/picture_test"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="101dp"
                    android:layout_marginTop="149dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/text_test" />
            </com.example.a33_plus_drawtest.PageView>

            <Space
                android:layout_width="match_parent"
                android:layout_height="10dp" />

            <com.example.a33_plus_drawtest.PageView
                android:id="@+id/page_view2"
                android:layout_width="377dp"
                android:layout_height="622dp"
                android:background="#888888" />
        </LinearLayout>
    </ScrollView>

</com.example.a33_plus_drawtest.ZoomableConstraintLayout>